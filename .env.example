# ── HuggingFace ───────────────────────────────────────────────────────────────
HUGGINGFACEHUB_API_TOKEN=hf_your_token_here

# ── LLM Configuration ─────────────────────────────────────────────────────────
REPO_ID=mistralai/Mistral-7B-Instruct-v0.2
MAX_NEW_TOKENS=512
TEMPERATURE=0.1

# ── Embedding Model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Vector Store ──────────────────────────────────────────────────────────────
INDEX_DIR=faiss_index

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=5
MMR_LAMBDA=0.8
SEARCH_TYPE=mmr

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
