# ── Groq API ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here

# ── LLM Configuration ─────────────────────────────────────────────────────────
REPO_ID=llama-3.1-8b-instant
MAX_NEW_TOKENS=1024
TEMPERATURE=0.1

# ── Embedding Model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Vector Store ──────────────────────────────────────────────────────────────
INDEX_DIR=faiss_index

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=8
MMR_LAMBDA=0.6
SEARCH_TYPE=mmr

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=200
CHUNK_OVERLAP=50

# ── App ───────────────────────────────────────────────────────────────────────
APP_TITLE=Rohanta's RAG Assistant
LOG_LEVEL=INFO

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
